params {
    // input parameters
    mutations_tsv = null
    bam_dir = null
    
    // reference genome
    reference = "/groups/wyattgrp/reference/hg38/hg38.fa"
    
    // output directory
    outdir = "results"
}

conda {
    enabled = true
}

profiles {
    slurm {
        executor {
            name = 'slurm'
            queueSize = 20
        }
        
        cpus     = 4
        memory   = '16 GB'
        time     = '6h'
        queue = 'express, normal, long, big-mem'    
        }

    local {
        executor {
            name = 'local'
        }
    }
}
